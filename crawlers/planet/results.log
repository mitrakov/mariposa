SELECT
    city,
    COUNT(*) as total,
    ROUND((COUNT(CASE WHEN gender = 'man'   THEN 1 END) * 100.0) / COUNT(*), 2) as men,
    ROUND((COUNT(CASE WHEN gender = 'woman' THEN 1 END) * 100.0) / COUNT(*), 2) as women
FROM planet.t_basic_etl
WHERE 
    lower(city) IN ('москва','санкт-петербург','новосибирск','нижний новгород','екатеринбург','пермь','великий новгород','псков')
    AND gender IN ('man', 'woman')
GROUP BY city
ORDER BY women DESC
;

