FROM eclipse-temurin:8
LABEL author="Artem Mitrakov (mitrakov-artem@yandex.ru)"

WORKDIR /root

RUN apt update && apt install --yes openssh-client
RUN wget --output-document hadoop.tar.gz https://downloads.apache.org/hadoop/common/hadoop-3.4.2/hadoop-3.4.2.tar.gz
RUN tar -xzf hadoop.tar.gz --directory /opt
RUN mv /opt/hadoop-3.4.2 /opt/hadoop
RUN rm hadoop.tar.gz

RUN useradd --system hadoop --shell /bin/bash

ENV JAVA_HOME=/opt/java/openjdk
ENV HADOOP_HOME=/opt/hadoop
ENV PATH=$PATH:$HADOOP_HOME/bin:$HADOOP_HOME/sbin

ENTRYPOINT ["tail", "-f", "/dev/null"]
