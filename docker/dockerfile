FROM eclipse-temurin:8
LABEL author="Artem Mitrakov (mitrakov-artem@yandex.ru)"

ENV JAVA_HOME=/opt/java/openjdk
ENV HADOOP_HOME=/opt/hadoop
ENV PATH=$PATH:$HADOOP_HOME/bin:$HADOOP_HOME/sbin

# ssh is required for Hadoop, sudo is required to start services
RUN apt update && apt install -y openssh-server sudo

# download Hadoop
RUN wget --output-document=- https://downloads.apache.org/hadoop/common/hadoop-3.4.2/hadoop-3.4.2.tar.gz | \
    tar --extract --gzip --directory /opt && mv /opt/hadoop-3.4.2 /opt/hadoop
RUN echo "export JAVA_HOME=/opt/java/openjdk" >> $HADOOP_HOME/etc/hadoop/hadoop-env.sh

# setup hadoop user
RUN useradd --create-home --shell /bin/bash hadoop && echo "hadoop ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers
USER hadoop

# SSH passwordless login for Hadoop
RUN ssh-keygen -t rsa -P '' -f ~/.ssh/id_rsa && cat ~/.ssh/id_rsa.pub >> ~/.ssh/authorized_keys

COPY entrypoint.sh /entrypoint.sh
ENTRYPOINT ["/bin/bash", "/entrypoint.sh"]
