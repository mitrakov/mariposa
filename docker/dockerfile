FROM eclipse-temurin:8
LABEL author="Artem Mitrakov (mitrakov-artem@yandex.ru)"

ENV HADOOP_HOME=/opt/hadoop
ENV SPARK_HOME=/opt/spark

# ssh is required for Hadoop, sudo is required to start services
RUN apt update && apt install -y openssh-server sudo mc

# download Apache Hadoop
RUN wget --output-document=- https://downloads.apache.org/hadoop/common/hadoop-3.4.2/hadoop-3.4.2.tar.gz | \
    tar --extract --gzip --directory /opt && mv /opt/hadoop-3.4.2 $HADOOP_HOME

# download Apache Spark
RUN wget --output-document=- https://downloads.apache.org/spark/spark-3.5.8/spark-3.5.8-bin-hadoop3.tgz | \
    tar --extract --gzip --directory /opt && mv /opt/spark-3.5.8-bin-hadoop3 $SPARK_HOME

# extra env variables, keep it after (!) massive downloads (HADOOP_CONF_DIR is needed for Yarn)
ENV JAVA_HOME=/opt/java/openjdk
ENV HADOOP_CONF_DIR=$HADOOP_HOME/etc/hadoop
ENV PATH=$PATH:$HADOOP_HOME/bin:$HADOOP_HOME/sbin:$SPARK_HOME/bin:$SPARK_HOME/sbin

# setup hadoop user, add it to "sudo", grant persmission for "dfs" dir, and switch to a new user
RUN useradd --create-home --shell /bin/bash hadoop && echo "hadoop ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers
USER hadoop

# add java home
RUN echo "export JAVA_HOME=$JAVA_HOME" >> $HADOOP_HOME/etc/hadoop/hadoop-env.sh

# SSH passwordless login for Hadoop
RUN ssh-keygen -t rsa -P '' -f ~/.ssh/id_rsa && cat ~/.ssh/id_rsa.pub >> ~/.ssh/authorized_keys

COPY entrypoint.sh /entrypoint.sh
ENTRYPOINT ["/bin/bash", "/entrypoint.sh"]
