# docker build --tag mitrakov/hadoop:1.0.0 .
FROM mitrakov/hadoop-tools:1.0.0
LABEL author="Artem Mitrakov (mitrakov-artem@yandex.ru)"

# extra env variables, keep it after massive downloads
# the HADOOP_CONF_DIR is needed for Yarn
ENV HADOOP_CONF_DIR=$HADOOP_HOME/etc/hadoop

# must-have
RUN echo "export JAVA_HOME=$JAVA_HOME" >> $HADOOP_CONF_DIR/hadoop-env.sh
RUN echo "export JAVA_HOME=$JAVA_HOME" >> $HBASE_HOME/conf/hbase-env.sh

# add hadoop user; add to sudoers; create folder for hadoop data; chown folders to hadoop:hadoop
RUN useradd --create-home --shell /bin/bash hadoop && \
    echo "hadoop ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers && \
    mkdir $HADOOP_HOME/dfs && \
    chown -R hadoop:hadoop $HADOOP_HOME && \
    chown -R hadoop:hadoop $HIVE_HOME && \
    chown -R hadoop:hadoop $HBASE_HOME
USER hadoop

# SSH passwordless login for Hadoop
RUN ssh-keygen -t rsa -P '' -f ~/.ssh/id_rsa && \
    cat ~/.ssh/id_rsa.pub >> ~/.ssh/authorized_keys

COPY entrypoint.sh /entrypoint.sh
ENTRYPOINT ["/bin/bash", "/entrypoint.sh"]
